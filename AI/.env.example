AI_SERVICE_NAME=KLTN AI Service
AI_DEBUG=false

# Local model mac dinh
LOCAL_LLM_MODEL=qwen2.5:3b

# Semantic embedding model
# Dung cho Semantic Search
SEMANTIC_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# =========================
# Cover Letter Provider
# Gia tri hop le: template | ollama | openai
# =========================
COVER_LETTER_PROVIDER=template

# =========================
# Chatbot Provider
# Gia tri hop le: template | ollama | openai
# =========================
CHATBOT_PROVIDER=template

# =========================
# Mock Interview Provider
# Gia tri hop le: rule_based | ollama
# =========================
MOCK_INTERVIEW_PROVIDER=ollama

# =========================
# Ollama local
# Dung khi muon bat AI local cho Cover Letter va/hoac Chatbot
# =========================
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b
MOCK_INTERVIEW_MAX_TOKENS=220

# =========================
# OpenAI cloud
# Dung khi COVER_LETTER_PROVIDER=openai
# =========================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1/responses

# =========================
# Cach dung nhanh
#
# 1. Template
# COVER_LETTER_PROVIDER=template
#
# 2. Ollama cho Cover Letter
# COVER_LETTER_PROVIDER=ollama
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=qwen2.5:3b
#
# 3. OpenAI
# COVER_LETTER_PROVIDER=openai
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1/responses
#
# 4. Semantic Search
# SEMANTIC_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#
# 5. Chatbot
# CHATBOT_PROVIDER=template
# CHATBOT_PROVIDER=ollama
#
# 6. Mock Interview
# MOCK_INTERVIEW_PROVIDER=ollama
# =========================
